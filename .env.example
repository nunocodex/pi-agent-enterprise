# TEMPLATE — copy to .env and fill in YOUR values.
# Never commit real IPs, tokens, or API keys here.
# This file is checked by CI for real-value contamination (S8).

# RAG Server Connection
RAG_API_IP=<RAG_API_IP>
RAG_API_PORT=8080

# RAG Ingestion Defaults
RAG_DOCS_PATH=./docs
RAG_DOCS_MAX_FILES=50

# Query Defaults
RAG_TOP_K=3
RAG_TIMEOUT=30
RAG_MAX_QUERY_LENGTH=4096
